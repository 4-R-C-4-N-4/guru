# corpus/ holds chunk data generated by scripts/chunk.py from raw/ sources.
# It is pipeline OUTPUT, not hand-edited source — review the chunker rules and
# tests, not the regenerated TOML. Marking it generated tells GitHub to collapse
# these files in PR diffs by default and exclude them from language stats, so
# cleanup PRs (which re-chunk many texts) stay navigable.
corpus/** linguist-generated=true
